# Инициализируем гит (если еще не сделано)
git init

# Создаем красивое описание проекта
echo "# Мой учебный проект" > README.md

# Добавляем абсолютно все файлы проекта в очередь на сохранение
git add .

# Делаем финальный "снимок" всех файлов
git commit -m "Готовый проект для сдачи ДЗ"

# Переходим на главную ветку main
git branch -M main

# Привязываем твой компьютер к GitHub 
# (ВСТАВЬ СВОЮ ССЫЛКУ ВМЕСТО ЭТОЙ)
git remote add origin ТВОЯ_ССЫЛКА_КОТОРУЮ_СКОПИРОВАЛ

# Выгружаем всё в интернет
git push -u origin main
